function findSmallestMissingPositive(orderNumbers) {
    const n = orderNumbers.length;
    let i = 0;
    
    //ordenação do array
    while( i < n) {
        const correctIndex = orderNumbers[i] - 1;
        
        if (orderNumbers[i] > 0 && 
            orderNumbers[i] <= n && 
            orderNumbers[i] !== orderNumbers[correctIndex]) {
            //Swap
            [orderNumbers[i], orderNumbers[correctIndex]] =
            [orderNumbers[correctIndex], orderNumbers[i]]
             
        }else{
            i++
        }
    }
    
    //busca do valor ausente
    for (let i = 0; i < n; i++) {
            if (orderNumbers[i] !== i + 1) {
                return (i + 1).toString();
            }
        }
        return (n + 1).toString();

}

Neste desafio, o algoritmo foi dividido em duas partes, o rearanjo do array e o escaneamento do menor valor inteiro. 
O primeiro compara o valor atual do array, "orderNumbers[i]", com o valor de "orderNumbers[i] - 1" e troca a posição de ambos até que o array
esteja em ordem crescente.

ex: array = [3, 4, -1, 1], i = 0 e orderNumbers[0] = 3, correctIndex = 3 - 1 = 2, logo correctIndex = índice 2 cujo valor é -1 e trocam a posições dos índices 0 e 2
1º array[-1, 4, 3, 1], i = 1 e orderNumbers[1] = 4, correctIndex = 4 - 1 = 3, logo correctIndex = índice 3 cujo valor é 1 e trocam as posições dos índices 1 e 3
2º array[1-, 1, 3, 4], i = 2 e orderNumbers[1] = 1, correctIndex = 1 - 1 = 0, logo correctIndex = índice 0 cujo valor é -1 e trocam a posições dos índices 1 e 0
3º array[1, -1, 3, 4] array ordernado

Assim que o array está ordenado, é verificado se o valor do índice "i" é o próximo número inteiro positivo na orderm crescente , índice 0 e valor 1, 
indice 1 e valor 2...

