function findFirstOccurrence(nums, target) {
    let left = 0;
    let right = nums.length - 1;
    let result = -1;
    
    while(left <= right){
        let mid = Math.floor((left + right) / 2);
        
        if(nums[mid] === target){
            result = mid;
            right = mid - 1;
        }else if(nums[mid] < target) {
            left = mid + 1;
        }else {
            right = mid - 1;
        }
    }
    return result;

}

